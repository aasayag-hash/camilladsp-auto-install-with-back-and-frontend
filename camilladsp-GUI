        all_f = self.config_raw.get("filters", {})
        self.filtros_biquad, self.filtros_crossover = {}, {}
        cross_types = ["ButterworthHighpass", "ButterworthLowpass", "LinkwitzRileyHighpass", "LinkwitzRileyLowpass"]
        
        for fid, d in all_f.items():

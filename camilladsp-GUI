                if d.get("type") == "Biquad":
                    self.filtros_biquad[fid] = {"data": d, "domain": domain, "channel": ch}
                elif d.get("type") == "BiquadCombo" and d.get("parameters", {}).get("type") in cross_types:
                    self.filtros_crossover[fid] = {"data": d, "domain": domain, "channel": ch}
        

pcm.inferno {
    type inferno
    @args.NAME { type string }
    @args.DEVICE_ID { type string }
    @args.BIND_IP { type string }
    @args.SAMPLE_RATE { type string }
    @args.PROCESS_ID { type string }
    @args.ALT_PORT { type string }
    @args.RX_CHANNELS { type string }
    @args.TX_CHANNELS { type string }
    @args.CLOCK_PATH { type string }
    @args.RX_LATENCY_NS { type string }
    @args.TX_LATENCY_NS { type string }
    NAME $NAME
    DEVICE_ID $DEVICE_ID
    BIND_IP $BIND_IP
    SAMPLE_RATE $SAMPLE_RATE
    PROCESS_ID $PROCESS_ID
    ALT_PORT $ALT_PORT
    RX_CHANNELS $RX_CHANNELS
    TX_CHANNELS $TX_CHANNELS
    CLOCK_PATH $CLOCK_PATH
    RX_LATENCY_NS $RX_LATENCY_NS
    TX_LATENCY_NS $TX_LATENCY_NS
}

pcm.inferno_rx {
    type inferno
    NAME "tvbox-dante"
    BIND_IP "192.168.1.180"
    SAMPLE_RATE "48000"
    RX_CHANNELS "2"
    TX_CHANNELS "0"
    PROCESS_ID "1007"
    CLOCK_PATH "/tmp/ptp-usrvclock"
    RX_LATENCY_NS "1000000"
}

pcm.inferno_tx {
    type inferno
    BIND_IP "192.168.1.180"
    SAMPLE_RATE "48000"
    RX_CHANNELS "0"
    TX_CHANNELS "2"
    PROCESS_ID "11"
    ALT_PORT "8700"
    CLOCK_PATH "/tmp/ptp-usrvclock"
    RX_LATENCY_NS "1000000"
    TX_LATENCY_NS "1000000"
}
